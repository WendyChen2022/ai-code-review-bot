# GitHub Personal Access Token with repo and pull_requests scopes
GITHUB_TOKEN=ghp_your_token_here

# Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# GitHub repository to watch (format: owner/repo)
GITHUB_REPO=owner/repo-name

# Optional: webhook secret for verifying GitHub webhook payloads
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: port to run the server on (default: 8000)
PORT=8000
